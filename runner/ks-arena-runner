#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-}"
shift || true

log() { echo "ks-arena-runner: $*" >&2; }

ensure_tools() {
  command -v kind >/dev/null
  command -v kubectl >/dev/null
}

ensure_tools_terraform() {
  ensure_tools
  command -v terraform >/dev/null
}

ensure_tools_test() {
  ensure_tools
  command -v clusterloader2 >/dev/null
}

kind_up() {
  local cluster_name=""
  local kind_config=""
  local terraform_dir=""
  local config_yaml=""
  local vars=()
  local images=()
  local manifests=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cluster-name)  cluster_name="$2"; shift 2;;
      --kind-config)   kind_config="$2"; shift 2;;
      --terraform-dir) terraform_dir="$2"; shift 2;;
      --config-yaml)   config_yaml="$2"; shift 2;;
      --var)           vars+=("$2"); shift 2;;
      --image)         images+=("$2"); shift 2;;
      --manifest)      manifests+=("$2"); shift 2;;
      *) log "argumento desconocido: $1"; exit 2;;
    esac
  done

  [[ -n "$cluster_name" ]] || { log "--cluster-name es obligatorio"; exit 2; }

  ensure_tools

  # Create KIND cluster
  local kind_args=(create cluster --name "$cluster_name" --wait "10m")
  if [[ -n "$kind_config" ]]; then
    kind_args+=(--config "/workspace/$kind_config")
  fi

  log "Creando cluster KIND: $cluster_name"
  kind "${kind_args[@]}"

  log "Exportando kubeconfig a /workspace/kubeconfig"
  kind get kubeconfig --name "$cluster_name" > /workspace/kubeconfig
  export KUBECONFIG=/workspace/kubeconfig

  log "Esperando a que el cluster responda..."
  for _ in $(seq 1 60); do
    if kubectl cluster-info >/dev/null 2>&1; then
      break
    fi
    sleep 2
  done

  # Load images into KIND (they must already exist in the host Docker daemon)
  for img in "${images[@]:-}"; do
    [[ -n "$img" ]] || continue
    log "Cargando imagen en KIND: $img"
    kind load docker-image "$img" --name "$cluster_name"
  done

  # Run Terraform if a terraform directory was provided
  if [[ -n "$terraform_dir" ]]; then
    ensure_tools_terraform
    log "Inicializando y aplicando Terraform en /workspace/$terraform_dir"
    terraform -chdir="/workspace/$terraform_dir" init -input=false

    tf_apply=(terraform -chdir="/workspace/$terraform_dir" apply -auto-approve -input=false)
    for kv in "${vars[@]:-}"; do
      tf_apply+=(-var "$kv")
    done
    "${tf_apply[@]}"
  fi

  # Apply manifests
  for manifest in "${manifests[@]:-}"; do
    [[ -n "$manifest" ]] || continue
    log "Aplicando manifest: $manifest"
    kubectl apply -f "/workspace/$manifest"
  done

  # Wait for pods in all namespaces to be ready (best-effort, don't fail the whole command)
  if [[ ${#manifests[@]} -gt 0 ]]; then
    log "Esperando a que los pods estén listos (timeout 3m)..."
    kubectl wait pod --all --all-namespaces --for=condition=ready --timeout=180s 2>/dev/null || \
      log "Algunos pods aún no están listos (pueden inicializarse más tarde)."
  fi

  log "OK"
}

kind_down() {
  local cluster_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cluster-name) cluster_name="$2"; shift 2;;
      *) log "argumento desconocido: $1"; exit 2;;
    esac
  done

  [[ -n "$cluster_name" ]] || { log "--cluster-name es obligatorio"; exit 2; }

  ensure_tools

  log "Eliminando cluster KIND: $cluster_name"
  kind delete cluster --name "$cluster_name"
  log "OK"
}

scheduler_apply() {
  local cluster_name=""
  local manifest=""
  local scheduler_image=""
  local kubeconfig_path="/workspace/kubeconfig"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cluster-name) cluster_name="$2"; shift 2;;
      --manifest)     manifest="/workspace/$2"; shift 2;;
      --image)        scheduler_image="$2"; shift 2;;
      --kubeconfig)   kubeconfig_path="/workspace/$2"; shift 2;;
      *) log "argumento desconocido: $1"; exit 2;;
    esac
  done

  [[ -n "$cluster_name" ]] || { log "--cluster-name es obligatorio"; exit 2; }
  [[ -n "$manifest" ]]     || { log "--manifest es obligatorio"; exit 2; }

  ensure_tools

  if [[ ! -f "$kubeconfig_path" ]]; then
    log "No existe kubeconfig en $kubeconfig_path. Ejecuta primero: ks-arena kind ..."
    exit 2
  fi

  export KUBECONFIG="$kubeconfig_path"

  # Load scheduler image into KIND if provided
  if [[ -n "$scheduler_image" ]]; then
    log "Cargando imagen del scheduler en KIND: $scheduler_image"
    kind load docker-image "$scheduler_image" --name "$cluster_name"
  fi

  log "Aplicando manifest del scheduler: $manifest"
  kubectl apply -f "$manifest"

  # Wait for the scheduler deployment to be ready
  log "Esperando al deployment del scheduler (timeout 2m)..."
  kubectl wait pod --all -n kube-system --for=condition=ready --timeout=120s \
    -l component=drs-scheduler 2>/dev/null || \
    log "El scheduler puede tardar unos segundos más en inicializarse."

  log "OK"
}

print_test_report() {
  local kubeconfig_path="$1"
  export KUBECONFIG="$kubeconfig_path"

  log ""
  log "======================================================="
  log "                    TEST REPORT"
  log "======================================================="
  log ""

  # Discover test namespaces created by CL2 (prefix drs-test-)
  local test_namespaces
  test_namespaces=$(kubectl get ns --no-headers 2>/dev/null \
    | awk '$1 ~ /^drs-test-/ {print $1}') || true

  if [[ -n "$test_namespaces" ]]; then
    # Pod-to-node distribution
    log "--- Pod distribution (scheduled by DRS) ---"
    local pods_running=0 pods_total=0 node_col=7
    while IFS= read -r ns; do
      local rows
      rows=$(kubectl get pods -n "$ns" -o wide --no-headers 2>/dev/null) || true
      [[ -z "$rows" ]] && continue
      local n_total n_running
      n_total=$(echo "$rows" | wc -l | tr -d ' ')
      n_running=$(echo "$rows" | awk '$3=="Running"{c++} END{print c+0}')
      pods_total=$(( pods_total + n_total ))
      pods_running=$(( pods_running + n_running ))
      echo "$rows" | while IFS= read -r line; do
        log "  [${ns}] $(echo "$line" | awk '{printf "%-42s  node=%-35s  status=%s\n",$1,$7,$3}')"
      done
    done <<< "$test_namespaces"

    log ""
    log "  Total pods: $pods_total  |  Running: $pods_running  |  Not running: $(( pods_total - pods_running ))"

    log ""
    log "--- Pods per node ---"
    while IFS= read -r ns; do
      kubectl get pods -n "$ns" -o wide --no-headers 2>/dev/null \
        | awk '{print $7}' | sort | uniq -c \
        | while read -r count node; do
            log "  $node  →  $count pod(s)"
          done
    done <<< "$test_namespaces"

    log ""
    log "--- Scheduling events ---"
    while IFS= read -r ns; do
      kubectl get events -n "$ns" \
        --field-selector reason=Scheduled \
        --sort-by=.lastTimestamp \
        --no-headers 2>/dev/null \
        | while IFS= read -r line; do log "  $line"; done || true
    done <<< "$test_namespaces"

    log ""
    log ""
    log "--- Pod startup latency (pod created → main container running) ---"
    local latency_tmp="/tmp/_pod_latencies_$$.txt"
    : > "$latency_tmp"
    while IFS= read -r ns; do
      local jsonpath='{range .items[*]}{.metadata.creationTimestamp}{"\t"}{.status.containerStatuses[0].state.running.startedAt}{"\n"}{end}'
      local pod_ts
      pod_ts=$(kubectl get pods -n "$ns" -l app=drs-test-pod \
        -o jsonpath="$jsonpath" 2>/dev/null) || continue
      [[ -z "$pod_ts" ]] && continue
      while IFS=$'\t' read -r created started; do
        [[ -z "$created" || -z "$started" ]] && continue
        local t0 t1
        t0=$(date -d "$created" +%s 2>/dev/null) || continue
        t1=$(date -d "$started"  +%s 2>/dev/null) || continue
        echo $(( t1 - t0 )) >> "$latency_tmp"
      done <<< "$pod_ts"
    done <<< "$test_namespaces"
    if [[ -s "$latency_tmp" ]]; then
      sort -n "$latency_tmp" | awk '
        BEGIN{n=0}
        {a[n++]=$1}
        END{
          if(n==0){print "  No data";exit}
          printf "  Samples: %d  P50: %ds  P90: %ds  P99: %ds  Max: %ds  Min: %ds\n",
            n,
            a[int(n*0.50)],
            a[int(n*0.90)],
            a[int(n*0.99 < n ? n*0.99 : n-1)],
            a[n-1],
            a[0]
        }'
      rm -f "$latency_tmp"
    else
      log "  No latency data (pods already exited or no containerStatus yet)."
    fi

    log ""
    # Cleanup test namespaces
    log "Limpiando namespaces de prueba..."
    while IFS= read -r ns; do
      kubectl delete namespace "$ns" --ignore-not-found 2>/dev/null || true
    done <<< "$test_namespaces"
  else
    log "  No test namespaces found."
  fi

  log ""
  log "--- Collector DRS scoring calls ---"
  local score_calls=0
  score_calls=$(kubectl logs -n monitoring deploy/collector \
    -c collector-agent 2>/dev/null \
    | grep -c "\[GetNodeScores\]" || true)
  log "  GetNodeScores invocations (lifetime): ${score_calls}"

  log "======================================================="
  log ""
}

run_test() {
  local cluster_name=""
  local kubeconfig_path="/workspace/kubeconfig"
  local test_config=""
  local repeat="1"
  local timeout_seconds=""
  local verbose="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cluster-name)    cluster_name="$2"; shift 2;;
      --kubeconfig)      kubeconfig_path="/workspace/$2"; shift 2;;
      --test-config)     test_config="/workspace/$2"; shift 2;;
      --repeat)          repeat="$2"; shift 2;;
      --timeout-seconds) timeout_seconds="$2"; shift 2;;
      --verbose)         verbose="true"; shift 1;;
      --config-yaml)     shift 2;; # trazabilidad únicamente
      *) log "argumento desconocido: $1"; exit 2;;
    esac
  done

  [[ -n "$cluster_name" ]] || { log "--cluster-name es obligatorio"; exit 2; }
  [[ -n "$test_config" ]]  || { log "--test-config es obligatorio"; exit 2; }

  ensure_tools_test

  if [[ ! -f "$kubeconfig_path" ]]; then
    log "No existe kubeconfig en $kubeconfig_path. Ejecuta primero: ks-arena kind ..."
    exit 2
  fi

  export KUBECONFIG="$kubeconfig_path"

  # Restart DRS scheduler so it is in a clean state (not in CrashLoopBackOff)
  # The scheduler exits when its queue is empty (leaderElect=false), which builds
  # up backoff between test runs. A rollout restart resets the crash counter.
  if kubectl get deployment/drs-scheduler -n kube-system &>/dev/null; then
    log "Reiniciando DRS scheduler (limpiando CrashLoopBackOff)..."
    kubectl rollout restart deployment/drs-scheduler -n kube-system
    kubectl wait pod -n kube-system -l component=drs-scheduler \
      --for=condition=ready --timeout=120s 2>/dev/null || \
      log "Advertencia: scheduler tardando en inicializarse, continuando..."
    log "DRS scheduler listo."
  fi

  # Keep test namespaces alive after CL2 finishes so the report can inspect them.
  # CL2 ignores deleteAutomanagedNamespaces from the testconfig file, so we use
  # the CLI flag (it shows a deprecation warning but still works correctly).
  local cl_args=(
    --kubeconfig "$kubeconfig_path"
    --testconfig "$test_config"
    --provider=kind
    --delete-automanaged-namespaces=false
  )

  log "Ejecutando ClusterLoader2 (repeat=$repeat)..."
  for i in $(seq 1 "$repeat"); do
    log "Run $i/$repeat"
    if [[ "$verbose" == "true" ]]; then
      clusterloader2 "${cl_args[@]}"
    else
      clusterloader2 "${cl_args[@]}" 2>&1 | tee "/workspace/clusterloader2-run-${i}.log"
    fi
    print_test_report "$kubeconfig_path"
  done

  log "OK"
}

case "$cmd" in
  kind)      kind_up "$@";;
  down)      kind_down "$@";;
  scheduler) scheduler_apply "$@";;
  test)      run_test "$@";;
  ""|-h|--help|help)
    cat <<'EOF'
ks-arena-runner (internal)

Commands:
  kind       --cluster-name NAME [--kind-config PATH] [--terraform-dir DIR] [--var k=v ...]
             [--image IMG ...] [--manifest PATH ...]
  down       --cluster-name NAME
  scheduler  --cluster-name NAME --manifest PATH [--image IMG] [--kubeconfig PATH]
  test       --cluster-name NAME [--kubeconfig PATH] --test-config PATH [--repeat N]
             [--timeout-seconds N] [--verbose]
EOF
    ;;
  *)
    log "comando desconocido: $cmd"
    exit 2
    ;;
esac
